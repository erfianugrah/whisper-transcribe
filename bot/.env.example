# Discord bot token — https://discord.com/developers/applications
DISCORD_TOKEN=

# Whisper transcription service
WHISPER_API_URL=http://localhost:7860

# LLM proxy (OpenAI-compatible).
# Since the bot now chunks long transcripts into 80k-char windows (see
# LLM_INPUT_CHAR_BUDGET below), any 7B-14B-class instruct model with a 32k+
# context window is sufficient — there's no benefit to using a 26B+ model for
# per-chunk summarization, and a smaller model keeps VRAM free for other
# workloads (ComfyUI, training, etc.).
LLM_API_URL=http://localhost:11434/v1
LLM_MODEL=Qwen3.5-4B-Q8_0

# Exa search API — used for terminology research (https://dashboard.exa.ai)
EXA_API_KEY=

# Optional: channel ID for detailed summaries (key points + chapters)
# Brief TL;DW stays in original channel, details go here
# SUMMARY_CHANNEL=123456789

# Optional: restrict bot to specific channel IDs (comma-separated)
# ALLOWED_CHANNELS=123456789,987654321

# Optional: soft runtime ceiling in seconds (default: 0 = no limit).
# Transcript size — not video duration — is what actually matters for the
# LLM context budget. Set this only if you want to bound disk/transcribe time.
# MAX_DURATION=0

# Optional: transcript cache TTL in seconds (default: 86400 = 24 hours)
# CACHE_TTL=86400

# Optional: LLM input char budget for the transcript portion of the prompt
# (default: 80000 ≈ 22k tokens, leaves ~10k for prompt+output in 32k ctx)
# LLM_INPUT_CHAR_BUDGET=80000

# Optional: LLM call parameters (sensible defaults baked in)
# LLM_TEMPERATURE=0.3
# LLM_MAX_TOKENS_BRIEF=1024
# LLM_MAX_TOKENS_KEY_POINTS=2048
# LLM_MAX_TOKENS_CHAPTERS=3000
# REFERENCE_CHAR_CAP=2000

# Optional: retry policy. RETRY_BACKOFF is CSV in seconds.
# MAX_RETRIES=3
# RETRY_BACKOFF=10,30,90

# Optional: Exa search tuning. EXA_EXCLUDE_DOMAINS is CSV.
# Default excludes only youtube.com (avoids circular refs to the same video's
# transcripts/comments). Add others if they pollute your results.
# EXA_NUM_RESULTS=5
# EXA_MAX_CHARACTERS=5000
# EXA_EXCLUDE_DOMAINS=youtube.com

# Optional: which video platforms trigger the bot. CSV of hostnames.
# Default covers the platforms yt-dlp commonly supports — add/remove freely.
# VIDEO_DOMAINS=youtube.com,youtu.be,m.youtube.com,music.youtube.com,twitch.tv,...

# Optional: hostnames the bot is allowed to link out to in posted summaries.
# Defense-in-depth against prompt-injection-driven phishing — links to anything
# else in the LLM output get stripped. CSV.
# ALLOWED_LINK_HOSTS=youtube.com,youtu.be,twitch.tv,vimeo.com

# ─── Vision-language fallback (silent / sparse-speech videos) ────────────────
# When a video has little or no speech, the bot can call the whisper
# service's /api/describe endpoint to generate frame-level descriptions and
# summarize those instead. Disable entirely with VLM_ENABLED=0.
#
# Speech density (chars/sec) decides routing:
#   density >= SPEECH_DENSITY_SPARSE  → speech-only (no VLM, current path)
#   SILENT <= density < SPARSE        → hybrid (speech + visual interleaved)
#   density < SPEECH_DENSITY_SILENT   → visual-only (VLM as transcript)
# Normal English speech is ~12 chars/sec; defaults below are well-calibrated.
# VLM_ENABLED=1
# SPEECH_DENSITY_SILENT=2.0
# SPEECH_DENSITY_SPARSE=8.0

# Frame sampling: one frame every VLM_FPS_INTERVAL seconds, capped at
# VLM_MAX_FRAMES total. Long videos auto-stretch the interval so a 2-hour
# video with max_frames=60 gets ~120s/frame, not 720 frames at 10s each.
# VLM_FPS_INTERVAL=10
# VLM_MAX_FRAMES=60
# VLM_TIMEOUT=1800   # seconds — worst case for max_frames @ ~30s/frame

# Optional: whisper model (tiny|base|small|medium|large|turbo, default: turbo)
# WHISPER_MODEL=turbo

# whisper-transcribe — root env file
# Copy to `.env` and fill in. The compose stack interpolates these into the
# whisper service environment.

# HuggingFace token for pyannote speaker diarization models.
# Get one at https://huggingface.co/settings/tokens (must accept the model
# licenses for pyannote/segmentation-3.0 and pyannote/speaker-diarization-3.1).
# Leave blank to disable diarization (transcription still works).
HF_TOKEN=

# ─── Vision-language fallback (whisper service) ──────────────────────────────
# Used by the /api/describe endpoint to summarize silent / music-only videos
# via frame extraction → VLM. The VLM call goes to the same llm-compose
# proxy the bot uses for text summaries.
#
# Default model assumes Qwen2.5-VL-7B-Instruct is configured on your
# llm-compose proxy. Any OpenAI-compatible vision model works; just set the
# right model id and url.
# LLM_VISION_API_URL=http://model_proxy:11434/v1
# LLM_VISION_MODEL=Qwen2.5-VL-7B-Instruct
# VLM_FPS_INTERVAL=10        # seconds between frames
# VLM_MAX_FRAMES=60          # cap; interval auto-stretches for long videos
# VLM_FRAME_WIDTH=512        # downscaled width for inference

# -- yt-dlp authentication (optional) -----------------------------------------
# Some YouTube videos require sign-in cookies:
#   - Age-restricted: "Sign in to confirm your age"
#   - Bot-flagged IPs: "Sign in to confirm you're not a bot"
#   - Members-only or private videos
# Without cookies these errors are now classified as permanent and the bot
# fails fast (no wasteful retries). To make these videos succeed, point this
# at a Netscape-format cookies.txt readable by the whisper container.
#
# Recommended setup: create a throwaway YouTube account, install the
# "Get cookies.txt LOCALLY" browser extension, export, save as
# ./cookies.txt at the repo root. Then uncomment both lines below and the
# corresponding volume in compose.yaml.
#
# Per-user Discord-driven cookie capture is intentionally NOT supported:
# storing full YouTube account credentials per Discord user is a security
# non-starter (DM transport, leak surface, expiry churn).
#
# YT_DLP_COOKIES_FILE=/secrets/cookies.txt

# whisper-transcribe — root env file
# Copy to `.env` and fill in. The compose stack interpolates these into the
# whisper service environment.

# HuggingFace token for pyannote speaker diarization models.
# Get one at https://huggingface.co/settings/tokens (must accept the model
# licenses for pyannote/segmentation-3.0 and pyannote/speaker-diarization-3.1).
# Leave blank to disable diarization (transcription still works).
HF_TOKEN=

# ─── Local media library (optional) ──────────────────────────────────────────
# Mount a host directory read-only into the whisper container so the Gradio
# "Local file" tab can pick up videos without re-uploading. Leave unset to
# disable (default mounts /dev/null harmlessly).
#
# Examples:
#   MEDIA_LIBRARY_PATH=/mnt/d/Videos       # WSL Windows D: drive
#   MEDIA_LIBRARY_PATH=/srv/media          # Linux NAS mount
#   MEDIA_LIBRARY_PATH=$HOME/Movies        # user home
# MEDIA_LIBRARY_PATH=

# ─── LLM endpoints ───────────────────────────────────────────────────────────
# Bot summaries + whisper VLM both speak OpenAI-compatible HTTP. The compose
# defaults target llm-compose's model_proxy on the `llmc` external network
# (declared `external: true` in compose.yaml). Bring llm-compose up first:
#     cd ~/llm-compose && make up
# Otherwise this stack fails to start with "network llmc not found".
#
# Override these to point at any compatible service:
#   Ollama on host:               http://host.docker.internal:11434/v1
#   llama.cpp server on host:     http://host.docker.internal:8080/v1
#   vLLM on host:                 http://host.docker.internal:8000/v1
#   OpenAI:                       https://api.openai.com/v1 (set bot env
#                                  OPENAI_API_KEY in bot/.env)
#
# LLM_API_URL=http://model_proxy:11434/v1                   # bot summaries
# LLM_MODEL=gemma-4-26B-A4B-it-Q4_K_M                       # bot model
# LLM_VISION_API_URL=http://model_proxy:11434/v1            # whisper /api/describe
# LLM_VISION_MODEL=gemma-4-26B-A4B-it-Q4_K_M                # vision model
# LLM_TEXT_API_URL=http://model_proxy:11434/v1              # whisper synthesis
# LLM_SYNTHESIS_MODEL=gemma-4-26B-A4B-it-Q4_K_M             # synthesis model
# VLM_FPS_INTERVAL=10        # seconds between frames
# VLM_MAX_FRAMES=60          # cap; interval auto-stretches for long videos
# VLM_FRAME_WIDTH=512        # downscaled width for inference

# -- yt-dlp authentication (optional) -----------------------------------------
# Some YouTube videos require sign-in cookies:
#   - Age-restricted: "Sign in to confirm your age"
#   - Bot-flagged IPs: "Sign in to confirm you're not a bot"
#   - Members-only or private videos
# Without cookies these errors are now classified as permanent and the bot
# fails fast (no wasteful retries). To make these videos succeed, point this
# at a Netscape-format cookies.txt readable by the whisper container.
#
# Recommended setup: create a throwaway YouTube account, install the
# "Get cookies.txt LOCALLY" browser extension, export, save as
# ./cookies.txt at the repo root. Then uncomment both lines below and the
# corresponding volume in compose.yaml.
#
# Per-user Discord-driven cookie capture is intentionally NOT supported:
# storing full YouTube account credentials per Discord user is a security
# non-starter (DM transport, leak surface, expiry churn).
#
# YT_DLP_COOKIES_FILE=/secrets/cookies.txt

# ─── Web URL summary (bot — "tldr" reply trigger) ────────────────────────────
# When a Discord user replies to a message containing a non-video URL with
# "tldr" or "summarize", the bot scrapes the article and posts brief +
# key_points + sections embeds. Two services involved:
#   crawl4ai     — primary scraper (Playwright + readability → Markdown)
#   flaresolverr — fallback for Cloudflare-challenged pages
#
# Compose wires the bot to both by container name; override only if you run
# them on a different host/port:
#   SCRAPER_API_URL=http://crawl4ai:11235
#   FLARESOLVERR_API_URL=http://flaresolverr:8191/v1
#
# Per-call timeout for /md (Crawl4AI). Long pages with many requests can
# exceed default; bumping to 180s for slow news sites is reasonable.
# SCRAPER_TIMEOUT=120
#
# Per-call timeout for FlareSolverr (used only when Crawl4AI fails). Each
# Chrome instance takes 10-30s to warm up + solve.
# FLARESOLVERR_TIMEOUT=90
